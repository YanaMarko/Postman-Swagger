            "exec": [
              "// данные запросы универсальные, их можно использовть для любого типа данных\r",
              "\r",
              "var jsonData = pm.response.json();\r",
              "\r",
              "pm.test(\"Checking for field content\", function () {\r",
              "    pm.expect(jsonData.quantity).to.eql(10);\r",
              "    console.log (jsonData.quantity);\r",
              "});\r",
              "\r",
              "// поле Не должно совпадать с заданным значением\r",
              "\r",
              "pm.test(\"Checking for field content\", function () {\r",
              "    pm.expect(jsonData.quantity).not.eql(1);\r",
              "    console.log (jsonData.quantity); \r",
              "});\r",
              "\r",
              "pm.test(\"Checking for field content\", function () {\r",
              "    pm.expect(jsonData.quantity).to.eql(null);\r",
              "    console.log (jsonData.quantity); \r",
              "});\r",
              "\r",
              "pm.test(\"Checking for field content\", function () {\r",
              "    pm.expect(jsonData.quantity).not.eql(null);\r",
              "    console.log (jsonData.quantity); \r",
              "});\r",
              "\r",
              "pm.test(\"Equal signs === to number\", function () {\r",
              "    pm.expect(jsonData.quantity === 10).to.be.true;\r",
              "    console.log (jsonData.quantity); \r",
              "});\r",
              "\r",
              ""
